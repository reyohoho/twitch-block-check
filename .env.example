# Port for the container to expose on the host
PORT=8000

# Geo provider preference:
#   ip-api  — ip-api.com        free, HTTP only, 45 req/min     (default)
#   ipwho   — ipwho.is          free, HTTPS, soft rate limit
#   ipapi   — ipapi.co          free, HTTPS, 1000 req/day
#   ipinfo  — ipinfo.io         free 50k/mo, HTTPS, needs IPINFO_TOKEN
#
# GEO_PROVIDER picks the first provider; the server automatically falls
# back to the others on HTTP 429 / network errors. Set GEO_PROVIDERS to
# override the whole chain explicitly, e.g.
#   GEO_PROVIDERS=ip-api,ipwho,ipapi
GEO_PROVIDER=ip-api
GEO_PROVIDERS=
IPINFO_TOKEN=

# Cache tuning (seconds). Defaults are sane; raise NEG_CACHE_TTL on heavy
# bot/spam traffic to spare upstream geo APIs.
GEO_CACHE_TTL=3600
GEO_NEG_CACHE_TTL=60
GEO_PROVIDER_COOLDOWN=120
GEO_HTTP_TIMEOUT=5.0

# Salt for hashing client IPs before storage (change for production!)
IP_HASH_SALT=change-me-please

# Logging
LOG_LEVEL=INFO
