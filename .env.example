# Port for the container to expose on the host
PORT=8000

# Geo provider:
#   ip-api  — ip-api.com        free, HTTP only, 45 req/min     (default)
#   ipwho   — ipwho.is          free, HTTPS, no hard rate limit
#   ipapi   — ipapi.co          free, HTTPS, 1000 req/day
#   ipinfo  — ipinfo.io         free 50k/mo, HTTPS, needs IPINFO_TOKEN
GEO_PROVIDER=ip-api
IPINFO_TOKEN=

# Salt for hashing client IPs before storage (change for production!)
IP_HASH_SALT=change-me-please

# Logging
LOG_LEVEL=INFO
